# Frontend Environment Variables Template
# Copy this file to .env and fill in the actual values

# ============================================
# API Configuration
# ============================================
# DEVELOPMENT: http://localhost:8080
# PRODUCTION: Your deployed backend URL
# Example: https://travelbuddy-backend.azurewebsites.net
VITE_API_BASE_URL=http://localhost:8080
VITE_REACT_APP_API_URL=http://localhost:8080

# ============================================
# Google Maps API Key
# ============================================
# CRITICAL: This is REQUIRED for map features
# Get your key from: https://console.cloud.google.com/google/maps-apis
# Restrict to HTTP referrers:
#  - https://travelbuddylk.com/*
#  - http://localhost:3000/*
#  - http://localhost:5173/*
VITE_GOOGLE_MAPS_API_KEY=your_frontend_maps_api_key_here

# ============================================
# Firebase Configuration
# ============================================
# Get these from: https://console.firebase.google.com/
# Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
